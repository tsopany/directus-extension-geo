{
	"name": "directus-extension-geo",
	"description": "Geo: Directus Extension for CountryStateCity",
	"icon": "extension",
	"version": "1.0.1",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-endpoint"
	],
	"type": "module",
	"files": [
		"dist"
	],
	"directus:extension": {
		"type": "endpoint",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^11.15.0"
	},
	"scripts": {
		"build": "pnpm fix && directus-extension build",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate",
		"lint": "eslint src test --no-fix",
		"linter": "eslint src test --no-fix --quiet",
		"lint:fix": "eslint src test --fix",
		"format": "prettier --log-level silent --write \"src/**/*.{js,json,ts}\"",
		"fix": "pnpm i && pnpm dedupe && skeletest -f && pnpm format && git add test && pnpm lint:fix && pnpm test",
		"quick": "vitest run",
		"test": "vitest run --coverage",
		"test:watch": "vitest watch",
		"l": "pnpm up -i -L"
	},
	"dependencies": {
		"@directus/extensions": "^3.0.22",
		"@exvorn/serbian-transliteration": "^1.0.0",
		"skeletest": "^0.7.4"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.1.4",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.5.0",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^10.1.0",
		"prettier": "^3.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.57.2",
		"vitest": "^4.1.1"
	},
	"license": "Unlicense",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsopany/directus-extension-geo.git"
	},
	"homepage": "https://github.com/tsopany/directus-extension-geo#readme",
	"bugs": {
		"url": "https://github.com/tsopany/directus-extension-geo/issues"
	},
	"packageManager": "pnpm@10.33.0"
}
