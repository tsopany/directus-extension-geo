{
	"printWidth": 180,
	"singleQuote": true,
	"trailingComma": "none",
	"arrowParens": "always",
	"useTabs": true,
	"bracketSpacing": false,
	"vueIndentScriptAndStyle": true,
	"bracketSameLine": true,
	"proseWrap": "never",
	"overrides": [
		{
			"files": "*.vue",
			"options": {
				"tailwindPreserveWhitespace": true
			}
		}
	]
}
